<%- include('partials/header') %>
 
      <div class="mb-16">

        <div
          class="inline-block rounded border border-cyan-400/30 px-4 py-2 text-xs uppercase tracking-[0.3em] text-cyan-400"
        >
          Premium Collection
        </div>

        <h2 class="mt-6 text-5xl md:text-6xl font-extrabold">
          Explore Our
          <span class="text-cyan-400">
            Products
          </span>
        </h2>

        <p class="mt-6 max-w-3xl text-lg text-slate-400">
          Discover innovative hardware and software solutions designed
          for developers, creators, startups, and modern businesses.
        </p>

      </div>

      
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

        <% products.forEach(product => { %>

          <div
            class="group overflow-hidden rounded-3xl border border-slate-800 bg-slate-900/50 backdrop-blur-xl transition duration-300 hover:-translate-y-2 hover:border-cyan-400/40"
          >

            <!-- Product Image -->
            <div class="overflow-hidden">
              <img
                src="<%= product.image %>"
                alt="<%= product.name %>"
                class="h-72 w-full object-cover transition duration-500 group-hover:scale-110"
              >
            </div>

            
            <div class="p-6">

              <div class="mb-3 flex items-center justify-between">

                <h3 class="text-2xl font-bold text-white">
                  <%= product.name %>
                </h3>

                <span
                  class="rounded-full bg-cyan-400/10 px-3 py-1 text-sm font-semibold text-cyan-400"
                >
                  New
                </span>

              </div>

              <p class="mb-4 text-3xl font-bold text-cyan-400 font-mono">
                <%= product.price %>৳
              </p>

              <p class="mb-6 text-slate-400">
                <%= product.description %>
              </p>

              <button
                class="w-full rounded-xl bg-cyan-400 px-4 py-3 font-semibold text-slate-950 transition hover:scale-[1.02]"
              >
                Add to Cart
              </button>

            </div>

          </div>

        <% }) %>

      </div>





<%- include('partials/footer') %>