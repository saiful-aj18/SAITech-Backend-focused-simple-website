<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title><%= typeof title !== 'undefined' ? title : 'My Simple Website' %></title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 overflow-x-hidden">

  <!-- Navbar -->
  <header class="sticky top-0 z-50 border-b border-cyan-500/10 bg-slate-950/80 backdrop-blur-xl">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex h-20 items-center justify-between">

        <h1 class="text-3xl font-bold tracking-wide">
          <span class="text-cyan-400">SAI</span>Tech
        </h1>

        <nav class="hidden md:flex items-center gap-8 text-sm uppercase tracking-widest">
          <a href="/" class="text-cyan-400 hover:text-cyan-400 font-bold hover:underline transition">Home</a>
          <a href="/about" class=" hover:text-cyan-400 hover:font-bold hover:underline  transition">About</a>
          <a href="/shop" class="hover:text-cyan-400 hover:font-bold hover:underline transition">Shop</a>
          <a href="/contact" class="hover:text-cyan-400 hover:font-bold hover:underline transition">Contact</a>
        </nav>

      </div>
    </div>
  </header>

    <main class="container mx-auto p-6 flex-grow bg-slate-950 my-6 shadow rounded">