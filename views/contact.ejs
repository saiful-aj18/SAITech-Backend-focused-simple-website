<%- include('partials/header') %>
 
      <div class="max-w-4xl">

        <div
          class="inline-block rounded border border-cyan-400/30 px-4 py-2 text-xs uppercase tracking-[0.3em] text-cyan-400"
        >
          Get In Touch
        </div>

        <h2
          class="mt-6 text-5xl md:text-6xl font-extrabold"
        >
          Contact
          <span class="text-cyan-400">
            SAITech
          </span>
        </h2>

        <p class="mt-6 text-lg text-slate-400">
          Have questions, feedback, or project ideas? We'd love to hear from
          you. Send us a message and our team will get back to you soon.
        </p>

      </div>

      
      <% if (typeof success !== 'undefined' && success) { %>

      <div
        class="mt-10 rounded-2xl border border-green-500/30 bg-green-500/10 p-5"
      >
        <h3 class="font-bold text-green-400">
          ✓ Message Sent Successfully
        </h3>

        <p class="mt-2 text-green-300">
          Your message has been received. Check your email for a confirmation.
        </p>
      </div>

      <% } %>

      <!-- Contact Layout -->
      <div class="mt-12 grid gap-8 lg:grid-cols-3">

        <!-- Contact Info -->
        <div
          class="rounded-3xl border border-slate-800 bg-slate-900/50 p-8 backdrop-blur-xl"
        >

          <h3 class="text-2xl font-bold text-white">
            Contact Information
          </h3>

          <div class="mt-8 space-y-6">

            <div>
              <p class="text-sm uppercase tracking-widest text-cyan-400">
                Email
              </p>
              <p class="mt-2 text-slate-400">
                contact@saitech.com
              </p>
            </div>

            <div>
              <p class="text-sm uppercase tracking-widest text-cyan-400">
                Phone
              </p>
              <p class="mt-2 text-slate-400">
                +880 1234 567890
              </p>
            </div>

            <div>
              <p class="text-sm uppercase tracking-widest text-cyan-400">
                Address
              </p>
              <p class="mt-2 text-slate-400">
                Chattogram, Bangladesh
              </p>
            </div>

          </div>

        </div>

        <!-- Contact Form -->
        <div
          class="lg:col-span-2 rounded-3xl border border-slate-800 bg-slate-900/50 p-8 backdrop-blur-xl"
        >

          <form action="/contact" method="POST">

            <div class="grid gap-6 md:grid-cols-2">

              <div>
                <label
                  for="name"
                  class="mb-2 block font-medium text-slate-300"
                >
                  Full Name
                </label>

                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none transition focus:border-cyan-400"
                >
              </div>

              <div>
                <label
                  for="email"
                  class="mb-2 block font-medium text-slate-300"
                >
                  Email Address
                </label>

                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none transition focus:border-cyan-400"
                >
              </div>

            </div>

            <div class="mt-6">

              <label
                for="message"
                class="mb-2 block font-medium text-slate-300"
              >
                Message
              </label>

              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none transition focus:border-cyan-400"
              ></textarea>

            </div>

            <button
              type="submit"
              class="mt-8 w-full rounded-xl bg-cyan-400 px-6 py-4 font-bold text-slate-950 transition hover:scale-[1.02]"
            >
              Send Message
            </button>

          </form>

        </div>

      </div>



<%- include('partials/footer') %>